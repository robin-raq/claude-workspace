{
  "name": "claude-workspace",
  "version": "0.1.0",
  "description": "WSL-first tmux workspace manager for structured Claude Code development sessions. Unofficial community project, not affiliated with or endorsed by Anthropic.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "cw": "dist/index.js"
  },
  "files": [
    "dist",
    "prompts"
  ],
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tmux",
    "wsl",
    "git-worktree",
    "workspace",
    "cli"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
